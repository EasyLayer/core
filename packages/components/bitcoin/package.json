{
  "name": "@easylayer/bitcoin",
  "version": "1.3.1",
  "description": "",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "browser": "./dist/browser/index.js",
      "module": "./dist/esm/index.js",
      "default": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "clear": "yarn run clear:dist && yarn run clear:node_modules",
    "clear:node_modules": "rimraf node_modules",
    "clear:dist": "rimraf dist",
    "test:unit": "jest --maxWorkers=1 -c ./jest.config.unit.mjs",
    "test": "yarn run test:unit",
    "lint": "eslint -c eslint.config.mjs \"src/**/*.ts\"",
    "lint:fix": "eslint -c eslint.config.mjs \"src/**/*.ts\" --fix",
    "format": "prettier -c prettier.config.mjs --write \"src/**/*.ts\"",
    "build:cjs": "tsc -b tsconfig.cjs.json",
    "build:esm": "tsc -b tsconfig.esm.json",
    "build:browser": "rollup -c rollup.config.mjs",
    "build:js": "yarn build:cjs && yarn build:esm && yarn build:browser",
    "native:target": "node ./scripts/native-platform.mjs",
    "build:native": "node ./scripts/build-native.mjs",
    "build": "yarn build:js && yarn build:native",
    "check:native-artifacts": "node ./scripts/check-native-artifacts.mjs"
  },
  "author": "Yaroslav Pavliuk",
  "license": "",
  "packageManager": "yarn@4.5.0",
  "dependencies": {
    "@bitcoinerlab/secp256k1": "1.2.0",
    "@easylayer/common": "1.3.1",
    "@nestjs/common": "10.2.10",
    "@nestjs/swagger": "7.1.17",
    "@noble/secp256k1": "3.0.0",
    "async-mutex": "0.5.0",
    "bip32": "4.0.0",
    "bip39": "3.1.0",
    "bitcoinjs-lib": "6.1.6",
    "bitcore-p2p": "10.10.7",
    "class-validator": "0.14.0",
    "class-validator-jsonschema": "5.0.0",
    "ecpair": "2.1.0",
    "fast-sha256": "1.3.0",
    "lodash": "4.17.21",
    "reflect-metadata": "0.1.14",
    "rxjs": "7.8.1",
    "uuid": "9.0.1",
    "zeromq": "6.5.0"
  },
  "devDependencies": {
    "@nestjs/testing": "10.2.10",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "11.1.6",
    "@types/bip32": "2.0.0",
    "@types/bip39": "3.0.0",
    "@types/bitcoinjs-lib": "5.0.0",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.11",
    "@types/lodash": "4.17.7",
    "@types/node": "20.10.4",
    "@types/uuid": "9.0.7",
    "@types/zeromq": "6.0.0",
    "jest": "29.7.0",
    "rollup": "4.17.2",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.2",
    "typescript": "5.3.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
